{
  "$schema": "../Schemas/PayrollEngine.Exchange.schema.json",
  "createdObjectDate": "{YYYY}-01-01T00:00:00.0Z",
  "tenants": [
    {
      "identifier": "{CC}.{RegulationName}",
      "updateMode": "NoUpdate",
      "regulations": [
        {
          "name": "{CC}.{RegulationName}",
          "updateMode": "NoUpdate",
          "validFrom": "{YYYY}-01-01T00:00:00Z",
          "wageTypes": [
            {
              "wageTypeNumber": 1000,
              "name": "MonthlySalary",
              "nameLocalizations": { "en": "Monthly Salary" },
              "description": "Gross monthly salary",
              "descriptionLocalizations": { "{PrimaryLanguage}": "Bruto maandsalaris" },
              "clusters": [ "{CC}" ],
              "valueActions": [ "^^MonthlySalary" ],
              "collectors": [ "GrossIncome" ]
            },
            {
              "wageTypeNumber": 5000,
              "name": "GrossWage",
              "nameLocalizations": { "en": "Gross Wage" },
              "description": "Gross wage total (GrossIncome collector)",
              "descriptionLocalizations": { "{PrimaryLanguage}": "Bruto loon totaal" },
              "clusters": [ "{CC}" ],
              "valueActions": [ "^&GrossIncome" ]
            },
            {
              "wageTypeNumber": 5100,
              "name": "TaxWithheld",
              "nameLocalizations": { "en": "Tax Withheld" },
              "description": "Income tax withheld — implement with BerekenBelasting custom action",
              "descriptionLocalizations": { "{PrimaryLanguage}": "Ingehouden belasting" },
              "clusters": [ "{CC}" ],
              "valueActions": [ "BerekenBelasting('{CC}.MonthlySalary')" ],
              "collectors": [ "Deductions" ]
            },
            {
              "wageTypeNumber": 6500,
              "name": "NetSalary",
              "nameLocalizations": { "en": "Net Salary" },
              "description": "Net salary (GrossIncome minus Deductions)",
              "descriptionLocalizations": { "{PrimaryLanguage}": "Nettoloon" },
              "clusters": [ "{CC}" ],
              "valueActions": [ "^&GrossIncome - ^&Deductions" ]
            }
          ]
        }
      ]
    }
  ]
}
