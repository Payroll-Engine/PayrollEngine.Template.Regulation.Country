{
  "$schema": "../Schemas/PayrollEngine.Exchange.schema.json",
  "createdObjectDate": "{YYYY}-01-01T00:00:00.0Z",
  "tenants": [
    {
      "identifier": "{CC}.{RegulationName}",
      "updateMode": "NoUpdate",
      "regulations": [
        {
          "name": "{CC}.{RegulationName}",
          "updateMode": "NoUpdate",
          "validFrom": "{YYYY}-01-01T00:00:00Z",
          "cases": [
            {
              "name": "Salary",
              "nameLocalizations": { "en": "Salary" },
              "description": "Employee salary",
              "descriptionLocalizations": { "{PrimaryLanguage}": "Salaris werknemer" },
              "caseType": "Employee",
              "clusters": [ "{CC}" ],
              "fields": [
                {
                  "name": "MonthlySalary",
                  "nameLocalizations": { "en": "Monthly Salary" },
                  "description": "Gross monthly salary",
                  "descriptionLocalizations": { "{PrimaryLanguage}": "Bruto maandsalaris" },
                  "valueType": "Money",
                  "timeType": "CalendarPeriod",
                  "clusters": [ "{CC}" ],
                  "buildActions": [
                    "SetFieldMinValue('MonthlySalary', 0)",
                    "SetFieldValueAdornment('MonthlySalary', '€')"
                  ]
                }
              ]
            },
            {
              "name": "Employment",
              "nameLocalizations": { "en": "Employment" },
              "description": "Employment contract data",
              "descriptionLocalizations": { "{PrimaryLanguage}": "Dienstverbandgegevens" },
              "caseType": "Employee",
              "clusters": [ "{CC}" ],
              "fields": [
                {
                  "name": "ContractType",
                  "nameLocalizations": { "en": "Contract Type" },
                  "description": "Employment contract type",
                  "descriptionLocalizations": { "{PrimaryLanguage}": "Soort arbeidscontract" },
                  "valueType": "String",
                  "timeType": "CalendarPeriod",
                  "clusters": [ "{CC}" ],
                  "buildActions": [
                    "SetFieldValueRequired('ContractType')"
                  ]
                }
              ]
            },
            {
              "name": "EmployerSettings",
              "nameLocalizations": { "en": "Employer Settings" },
              "description": "Employer configuration",
              "descriptionLocalizations": { "{PrimaryLanguage}": "Werkgeverconfiguratie" },
              "caseType": "Company",
              "clusters": [ "{CC}" ],
              "fields": [
                {
                  "name": "TaxRegistration",
                  "nameLocalizations": { "en": "Tax Registration" },
                  "description": "Employer tax registration number",
                  "descriptionLocalizations": { "{PrimaryLanguage}": "Belastingregistratienummer werkgever" },
                  "valueType": "String",
                  "timeType": "CalendarPeriod",
                  "clusters": [ "{CC}" ],
                  "buildActions": [
                    "SetFieldValueRequired('TaxRegistration')"
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
