{
  "$schema": "../../Schemas/PayrollEngine.Exchange.schema.json",
  "createdObjectDate": "{YYYY}-01-01T00:00:00.0Z",
  "tenants": [
    {
      "identifier": "{CC}.{RegulationName}",
      "users": [
        {
          "identifier": "{cc}.test@{cc}.test",
          "firstName": "Test",
          "lastName": "User",
          "culture": "{PrimaryLanguage}"
        }
      ],
      "divisions": [
        {
          "name": "{CC}.Division",
          "culture": "{PrimaryLanguage}",
          "calendar": "Gregorian"
        }
      ],
      "employees": [
        {
          "identifier": "test.employee@{cc}.test",
          "firstName": "Test",
          "lastName": "Employee",
          "culture": "{PrimaryLanguage}",
          "divisionNames": [ "{CC}.Division" ]
        }
      ],
      "payrolls": [
        {
          "name": "{CC}.Payroll",
          "divisionName": "{CC}.Division",
          "layers": [
            { "level": 1, "priority": 1, "regulationName": "{CC}.{RegulationName}" },
            { "level": 1, "priority": 2, "regulationName": "{CC}.{RegulationName}.Data.Tax" }
          ]
        }
      ],
      "payruns": [
        {
          "name": "{CC}.Payrun",
          "payrollName": "{CC}.Payroll"
        }
      ]
    }
  ]
}
