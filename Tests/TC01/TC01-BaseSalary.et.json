{
  "$schema": "../../Schemas/PayrollEngine.Exchange.schema.json",
  "createdObjectDate": "{YYYY}-01-01T00:00:00.0Z",
  "tenants": [
    {
      "identifier": "{CC}.{RegulationName}",
      "updateMode": "NoUpdate",
      "payrolls": [
        {
          "name": "{CC}.Payroll",
          "updateMode": "NoUpdate",
          "cases": [
            {
              "userIdentifier": "{cc}.test@{cc}.test",
              "employeeIdentifier": "test.employee@{cc}.test",
              "divisionName": "{CC}.Division",
              "case": {
                "caseName": "{CC}.Salary",
                "values": [
                  { "caseFieldName": "{CC}.MonthlySalary", "value": "3000", "start": "{YYYY}-01-01T00:00:00.0Z" }
                ]
              }
            },
            {
              "userIdentifier": "{cc}.test@{cc}.test",
              "employeeIdentifier": "test.employee@{cc}.test",
              "divisionName": "{CC}.Division",
              "case": {
                "caseName": "{CC}.Employment",
                "values": [
                  { "caseFieldName": "{CC}.ContractType", "value": "Permanent", "start": "{YYYY}-01-01T00:00:00.0Z" }
                ]
              }
            }
          ]
        }
      ],
      "payrunJobInvocations": [
        {
          "name": "{CC}.TC01",
          "payrunName": "{CC}.Payrun",
          "userIdentifier": "{cc}.test@{cc}.test",
          "completedJobStatus": "Complete",
          "periodStart": "{YYYY}-01-01T00:00:00.0Z",
          "evaluationDate": "{YYYY}-02-01T00:00:00.0Z",
          "reason": "TC01 - Base salary, standard tax",
          "employeeIdentifiers": [ "test.employee@{cc}.test" ]
        }
      ],
      "payrollResults": [
        {
          "payrunJobName": "{CC}.TC01",
          "employeeIdentifier": "test.employee@{cc}.test",
          "wageTypeResults": [
            { "wageTypeNumber": 1000, "value": 3000.00 },
            { "wageTypeNumber": 5100, "value": 175.00 },
            { "wageTypeNumber": 6500, "value": 2825.00 }
          ],
          "collectorResults": [
            { "collectorName": "{CC}.GrossIncome", "value": 3000.00 },
            { "collectorName": "{CC}.Deductions",  "value": 175.00 }
          ]
        }
      ]
    }
  ]
}
